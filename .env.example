# ============================================
# AI Pulse — Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# --- Anthropic (Claude API) ---
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929
ANTHROPIC_MAX_TOKENS=4096

# --- Beehiiv (Newsletter) ---
# Create account: https://www.beehiiv.com
# Get API key: Settings → Integrations → API
BEEHIIV_API_KEY=
BEEHIIV_PUBLICATION_ID=pub_...

# --- Twitter/X (API v2) ---
# Create app: https://developer.twitter.com/en/portal
# Need Elevated access for posting
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=

# --- ElevenLabs (TTS) ---
# Create account: https://elevenlabs.io
# Get API key: Profile → API Keys
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb
ELEVENLABS_MODEL=eleven_multilingual_v2

# --- YouTube (Data API v3) ---
# Create project: https://console.cloud.google.com
# Enable YouTube Data API v3
# Create OAuth 2.0 credentials
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=

# --- Reddit API ---
# Create app: https://www.reddit.com/prefs/apps
# Type: script
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=ai-pulse:v1.0.0 (by /u/your-username)

# --- ProductHunt API ---
# Create app: https://www.producthunt.com/v2/oauth/applications
PRODUCTHUNT_ACCESS_TOKEN=

# --- Sources Configuration ---
SOURCE_HACKERNEWS_ENABLED=true
SOURCE_HACKERNEWS_MAX=30
SOURCE_REDDIT_ENABLED=true
SOURCE_REDDIT_MAX=20
SOURCE_TECHCRUNCH_ENABLED=true
SOURCE_TECHCRUNCH_MAX=15
SOURCE_ARXIV_ENABLED=true
SOURCE_ARXIV_MAX=10
SOURCE_PRODUCTHUNT_ENABLED=true
SOURCE_PRODUCTHUNT_MAX=10
SOURCE_RSS_ENABLED=true
SOURCE_RSS_MAX=15

# --- Pipeline ---
PIPELINE_CRON=0 7 * * *
PIPELINE_TIMEZONE=America/New_York
PIPELINE_MAX_RETRIES=3
PIPELINE_RETRY_DELAY_MS=5000

# --- Storage ---
DB_PATH=./data/ai-pulse.db

# --- Content ---
CONTENT_NEWSLETTER_NAME=AI Pulse
CONTENT_TWITTER_HANDLE=@ai_pulse_daily
CONTENT_YOUTUBE_CHANNEL=AI Pulse
CONTENT_TOP_STORIES=5
CONTENT_MAX_ARTICLES=20

# --- Logging ---
LOG_LEVEL=info
